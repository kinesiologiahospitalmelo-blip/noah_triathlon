{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd noah_coach && npm install && CI=false npm run build",
  "outputDirectory": "noah_coach/build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/app.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
