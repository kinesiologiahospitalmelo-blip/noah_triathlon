{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "app.py", "use": "@vercel/python" },
    {
      "src": "noah_coach/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/app.py" },
    { "src": "/(.*)", "dest": "/noah_coach/build/$1" }
  ]
}
