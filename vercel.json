{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd noa-coach && npm install && npm run build",
  "outputDirectory": "noa-coach/build",
  "routes": [
    { "src": "/api/(.*)", "dest": "/app.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
